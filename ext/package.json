{
    "name": "vex-lang",
    "displayName": "Vex Language",
    "description": "Vex programming language support",
    "version": "0.0.1",
    "engines": {
        "vscode": "^1.75.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "contributes": {
        "languages": [{
            "id": "vex",
            "aliases": ["Vex", "vex"],
            "extensions": [".vx"],
            "configuration": "./language-configuration.json"
        }],
        "grammars": [{
            "language": "vex",
            "scopeName": "source.vx",
            "path": "./syntaxes/vex.tmLanguage.json"
        }]
    }
}