{
    "comments": {
        "lineComment": "#"
    },
    "brackets": [
        ["(", ")"],
        ["{", "}"],
        ["[", "]"]
    ],
    "autoClosingPairs": [
        ["(", ")"],
        ["{", "}"],
        ["[", "]"],
        ["\"", "\""],
        ["'", "'"]
    ],
    "onEnterRules": [
        {
            "beforeText": ":\\s*$",
            "action": { "indent": "indent" }
        }
    ]
}